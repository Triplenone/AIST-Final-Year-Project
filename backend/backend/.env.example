# Copy this file to `.env` and edit values as needed.

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=smart_elderly_care_system

# App
DEBUG=True
API_V1_PREFIX=/api/v1
APP_NAME=智能养老系统API
APP_VERSION=1.0.0

# MQTT
MQTT_BROKER=broker.emqx.io
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
DEVICE_ID_MAP_JSON={"ESP32_00005CFA7AD4DB1C":1}

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=smart_elderly_care_system
